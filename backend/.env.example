# Backend environment variables
# Copy this file to: backend/.env and fill in real values before starting the server.

# Server
PORT=5500

# JWT - used to sign auth tokens
# Use a long random secret in production
JWT_SECRET=change_me_to_a_long_random_secret

# MySQL / MariaDB
# If you run MySQL locally, set DB_USER/DB_PASSWORD accordingly.
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=meriams_shop

# Stripe (optional - leave empty if not using)
# Use test keys during development: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# PayPal (optional) - install PayPal SDK and set these to enable PayPal
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_SECRET=YOUR_PAYPAL_SECRET

# Frontend URL used for redirect after payment (update if frontend runs on different port)
FRONTEND_URL=http://localhost:5500

